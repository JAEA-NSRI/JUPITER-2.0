include(CMakeFindDependencyMacro)

set(JUPITER_ENABLE_OPENMP "@ENABLE_OPENMP@")
set(JUPITER_ENABLE_MPI "@ENABLE_MPI@")

if(JUPITER_ENABLE_MPI)
  find_dependency(MPI)
endif()
if(JUPITER_ENABLE_OPENMP)
  find_dependency(OpenMP)
endif()

foreach(LIB re2c_lparser Geometry Table Serializer Control Random LPT LPTX OS
    JUPITER vtkiobind cxxoptparse vtkIOJUPITER vtkJUPITER)
  set(FILE ${CMAKE_CURRENT_LIST_DIR}/${LIB}.cmake)
  if(EXISTS "${FILE}")
    include("${FILE}")
  endif()
endforeach()
