
set(EXEC      "$<TARGET_FILE:csvtest>")
set(DIRECTORY "@CMAKE_CURRENT_SOURCE_DIR@/input")
set(TMPDIR    "@CMAKE_CURRENT_BINARY_DIR@/csvtestTmp")
set(MPIEXEC   "@MPIEXEC@")
set(MPIEXEC_NUMPROC_FLAG "@MPIEXEC_NUMPROC_FLAG@")

if (EXEC STREQUAL "" OR DIRECTORY STREQUAL "" OR TMPDIR STREQUAL "")
  message(FATAL_ERROR "No executable (EXEC), directory (DIRECTORY), temporary dir (TMPDIR) given")
endif()

if(NOT MPIEXEC STREQUAL "")
  set(__MPI "${MPIEXEC}" ${MPIEXEC_NUMPROC_FLAG} 1)
else()
  set(__MPI)
endif()

file(GLOB LIST "${DIRECTORY}/*.txt")
execute_process(COMMAND ${__MPI} "${EXEC}" ${LIST}
  OUTPUT_FILE "${TMPDIR}/csvtestInfo.cmake"
  RESULT_VARIABLE RETV)

if (NOT ${RETV} EQUAL 0)
  message(SEND_ERROR "Faled to run ${EXEC}")
endif()

function(getcell RET VAR IR IC)
  set(_S "${${VAR}}")
  set(_IR "${${IR}}")
  set(_IC "${${IC}}")
  if("${_S}" STREQUAL "")
    return()
  endif()
  string(FIND "${_S}" "
" NLLOC)
  while(NLLOC EQUAL 0)
    string(SUBSTRING "${_S}" 1 -1 _S)
    string(FIND "${_S}" "
" NLLOC)
    math(EXPR _IR "${_IR} + 1")
    set(_IC 0)
  endwhile()
  math(EXPR _IC "${_IC} + 1")
  string(SUBSTRING "${_S}" 0 ${NLLOC} _R)
  string(REGEX MATCH "^([^;]|\\\\;)*;" _C "${_R}")
  if("${_C}" STREQUAL "")
    set(_C "${_R}")
    string(LENGTH "${_C}" L)
  else()
    string(LENGTH "${_C}" L)
    math(EXPR LL "${L} - 1")
    string(SUBSTRING "${_C}" 0 ${LL} _C)
  endif()
  string(SUBSTRING "${_S}" ${L} -1 _S)
  set(${RET} "${_C}" PARENT_SCOPE)
  set(${VAR} "${_S}" PARENT_SCOPE)
  set(${IC} "${_IC}" PARENT_SCOPE)
  set(${IR} "${_IR}" PARENT_SCOPE)
endfunction()

macro(csv_compare BNN)
  set(IR_RES 1)
  set(IC_RES 0)
  set(IR_REF 1)
  set(IC_REF 0)
  set(RET 0)
  getcell(TOKREF DATA IR_REF IC_REF)
  getcell(TOKRES DATA_RESULT IR_RES IC_RES)
  while(0 EQUAL 0)
    set(__F OFF)
    if(IR_RES EQUAL IR_REF AND IC_RES EQUAL IC_REF)
      if (NOT TOKRES STREQUAL TOKREF)
        message(SEND_ERROR "[${BNN}] Compare error:
 Cell row ${IR_RES} and column ${IC_RES}
   must be \"${TOKREF}\",
   but got \"${TOKRES}\"
")
        set(RET 1)
      endif()
      if(DATA STREQUAL "" AND DATA_RESULT STREQUAL "")
        break()
      endif()
      getcell(TOKREF DATA IR_REF IC_REF)
      getcell(TOKRES DATA_RESULT IR_RES IC_RES)
    else()
      if(IR_RES EQUAL IR_REF AND IC_RES GREATER IC_REF)
        set(__F ON)
      elseif(IR_RES GREATER IR_REF)
        set(__F ON)
      endif()
      if(__F)
        message(SEND_ERROR "[${_BNN}] Compare error:
 Extra Cell row ${IR_RES} column ${IC_RES} found
 with \"${TOKRES}\"
")
        set(RET 1)
        if(DATA STREQUAL "" AND DATA_RESULT STREQUAL "")
          break()
        endif()
        getcell(TOKREF DATA IR_REF IC_REF)
      else()
        message(SEND_ERROR "[${_BNN}] Compare error:
 Cell row ${IR_REF} column ${IC_REF} should be \"${TOKREF}\"
 but it does not found in the result.
")
        set(RET 1)
        if(DATA STREQUAL "" AND DATA_RESULT STREQUAL "")
          break()
        endif()
        getcell(TOKRES DATA_RESULT IR_RES IC_RES)
      endif()
    endif()
  endwhile(0 EQUAL 0)
  if (RET EQUAL 0)
    message(STATUS "[${_BNN}] All cell comparison OK.")
  endif()
endmacro()

include("${TMPDIR}/csvtestInfo.cmake")
