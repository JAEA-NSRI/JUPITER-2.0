if (POLICY CMP0054)
  cmake_policy(SET CMP0054 NEW)
endif()
if (POLICY CMP0011)
  cmake_policy(SET CMP0011 NEW)
endif()

include("@VARCONFIG@")
include("@BINCONFIG@")

include("@JUPITER_INPUT_TEST_UTIL_SCRIPT@")
print_test_conf()

include("@JUPITER_RUN_SCRIPT@")
@RESTART_RUN_SCRIPTS@
include("@COMPARE_RUN_SCRIPT@")

set(SKIP_MKVTK_EXECUTABLE  "@JUPITER_INPUT_TEST_SKIP_MKVTK@")
set(SKIP_MKVTKU_EXECUTABLE "@JUPITER_INPUT_TEST_SKIP_MKVTKU@")
set(SKIP_MKXDMF_EXECUTABLE "@JUPITER_INPUT_TEST_SKIP_MKXDMF@")

foreach(_X MKVTK MKVTKU MKXDMF)
  set(EN ENV{SKIP_${_X}})
  if(DEFINED "${EN}")
    set(SKIP_${_X}_EXECUTABLE "${EN}")
  endif()
endforeach()

@MKVTK_RUN_SCRIPTS@
