
if (POLICY CMP0054)
  cmake_policy(SET CMP0054 NEW)
endif()

include("@VARCONFIG@")
include("@BINCONFIG@")

include("@JUPITER_INPUT_TEST_UTIL_SCRIPT@")
print_test_conf()

message(STATUS "@MAKE_VTK_EXECUTABLE_NAME@: ${@MAKE_VTK_EXECUTABLE@}")
if(NOT @MAKE_VTK_EXECUTABLE@)
  message(STATUS "@MAKE_VTK_EXECUTABLE_NAME@ is not available")
  return()
endif()

set(MAKE_VTK_ARGS "@MAKE_VTK_ARGS@")
set(MAKE_VTK_SKIP_INDICES @MAKE_VTK_SKIP_INDICES@)
set(MAKE_VTK_SKIP_MAKE_DIRECTORY @MAKE_VTK_SKIP_MAKE_DIRECTORY@)
set(MAKE_VTK_OUTDIR "@MAKE_VTK_OUTDIR@")
set(MAKE_VTK_EXPECT "@MAKE_VTK_EXPECT@")
set(MAKE_VTK_EXPECT_NO_INDICES "@MAKE_VTK_EXPECT_NO_INDICES@")
set(MAKE_VTK_RESTART "@MAKE_VTK_RESTART@")

find_compare_files(BINARY_TIME RESTART ${RESTART}
  WORKING_DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}"
  REFERENCE_DIRECTORY "${REFDIR}"
  PATTERNS "${BINOUTD0}/${BTIMEF0}"
  RESTART_PATTERNS "${BINOUTD1}/${BTIMEF1}")

list(LENGTH BINARY_TIME_FILES N)
if(N GREATER 0)
  math(EXPR N "${N}-1")
  foreach(I RANGE "${N}")
    list(GET BINARY_TIME_USE_RESTART "${I}" UR)
    list(GET BINARY_TIME_TIMESTEP_INDICES "${I}" TI)
    list(APPEND INDICES${UR} "${I}")
  endforeach()
endif()

foreach(R IN LISTS REST_CON)
  if(R EQUAL 0)
    set(M "")
  else()
    set(M " from restart run")
  endif()
  list(REMOVE_DUPLICATES INDICES${R})
  message(STATUS "Found indices${M}: ${INDICES${R}}")
endforeach()

set(BINDIRS)
set(RESDIRS)
foreach(R IN LISTS REST_CON)
  list(APPEND BINDIRS "${BINOUTD${R}}")
  list(APPEND RESDIRS "${RESOUTD${R}}")
endforeach()
set(RUNDIRS ${BINDIRS} ${RESDIRS})
list(REMOVE_DUPLICATES RUNDIRS)

set(INDICES)
set(INDICES_DIR)
set(INDICES_UR)
foreach(R IN LISTS REST_CON)
  if(NOT TIME_INDICES${R})
    set(L INDICES${R})
  else()
    set(L TIME_INDICES${R})
  endif()
  list(FIND RUNDIRS "${BINOUTD${R}}" DIRIDX)
  foreach(I IN LISTS ${L})
    list(APPEND INDICES "${I}")
    list(APPEND INDICES_DIR "${DIRIDX}")
    list(APPEND INDICES_UR "${R}")
  endforeach()
  if(MAKE_VTK_RESTART)
    list(FIND RUNDIRS "${RESOUTD${R}}" DIRIDX)
    list(APPEND INDICES "-1")
    list(APPEND INDICES_DIR "${DIRIDX}")
    list(APPEND INDICES_UR "${R}")
  endif()
endforeach()

set(OUTDIR "${MAKE_VTK_OUTDIR}")
if("${OUTDIR}" STREQUAL "")
  set(OUTDIR ".")
endif()
if(IS_ABSOLUTE "${OUTDIR}")
  file(RELATIVE_PATH OUTDIR "${CMAKE_CURRENT_SOURCE_DIR}" "${OUTDIR}")
endif()
if(EXISTS "${OUTDIR}")
  if("${OUTDIR}" STREQUAL "." OR "${OUTDIR}" MATCHES [[^\.\./]])
    message(WARNING "Not removing/create output directory '${OUTDIR}'")
    set(MAKE_VTK_SKIP_MAKE_DIRECTORY TRUE)
  else()
    file(REMOVE_RECURSE "${OUTDIR}")
  endif()
endif()
if(NOT MAKE_VTK_SKIP_MAKE_DIRECTORY)
  message(STATUS "Creating '${OUTDIR}'")
  file(MAKE_DIRECTORY "${OUTDIR}")
endif()

set(RUNC 0)
list(LENGTH RUNDIRS N)
list(LENGTH INDICES NI)
if(N GREATER 0 AND NI GREATER 0)
  math(EXPR N "${N}-1")
  math(EXPR NI "${NI}-1")
  foreach(DIRIDX RANGE ${N})
    list(GET RUNDIRS "${DIRIDX}" DIR)
    foreach(R IN LISTS REST_CON)
      set(IDXS)
      foreach(IDX RANGE ${NI})
        list(GET INDICES_DIR "${IDX}" DI)
        list(GET INDICES_UR "${IDX}" UR)
        if("${DI}" EQUAL "${DIRIDX}" AND "${R}" EQUAL "${UR}")
          list(GET INDICES "${IDX}" I)
          list(APPEND IDXS "${I}")
        endif()
      endforeach()
      if(R EQUAL 0)
        set(M)
      else()
        set(M " with restart inputs")
      endif()

      message(STATUS "Run for indices ${IDXS} in ${DIR}${M}")
      set(ARGS "${MAKE_VTK_ARGS}")
      list(APPEND ARGS "--input-directory=${DIR}")
      if(NOT OUTDIR STREQUAL "")
        list(APPEND ARGS "--output-directory=${OUTDIR}")
      endif()
      if("-1" IN_LIST IDXS)
        if(MAKE_VTK_SKIP_INDICES)
          set(IDXS "--" "-1")
        else()
          list(PREPEND "--" IDXS)
        endif()
      elseif(MAKE_VTK_SKIP_INDICES)
        set(IDXS)
      endif()
      make_vtk_args(_R RESTART "${R}"
        COMMAND "${@MAKE_VTK_EXECUTABLE@}" ARGS ${ARGS} ${IDXS})
      list(JOIN _R " " COMSTR)
      message(STATUS "Executing: ${COMSTR}")
      set(OUTPUT_FILE "${NAME}-@MAKE_VTK_OUTNAME@-${RUNC}.out")
      set(ERROR_FILE  "${NAME}-@MAKE_VTK_OUTNAME@-${RUNC}.err")
      message(STATUS "-> stdout: ${OUTPUT_FILE}")
      message(STATUS "-> stderr: ${ERROR_FILE}")
      execute_process(COMMAND ${_R}
        OUTPUT_FILE "${OUTPUT_FILE}"
        ERROR_FILE "${ERROR_FILE}"
        RESULT_VARIABLE _RET)
      message(STATUS "Return value: ${_RET}")
      if(NOT "${MAKE_VTK_EXPECT}" STREQUAL "")
        if(IDXS)
          set(_V MAKE_VTK_EXPECT)
        else()
          set(_V MAKE_VTK_EXPECT_NO_INDICES)
        endif()
        if(NOT "${${_V}}" EQUAL "${_RET}")
          message(SEND_ERROR
            "@MAKE_VTK_EXECUTABLE_NAME@ returned ${_RET} but expect ${${_V}}")
        endif()
      endif()
      math(EXPR RUNC "${RUNC}+1")
    endforeach()
  endforeach()
endif()
